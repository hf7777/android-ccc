<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:background="@color/white"
    android:orientation="horizontal">

    <LinearLayout
        android:id="@+id/tab1"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="4dp">

        <ImageView
            android:id="@+id/tab1_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="@string/tab_home"
            android:src="@drawable/ic_home" />

        <TextView
            android:id="@+id/tab1_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/tab_home"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tab2"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="4dp">

        <ImageView
            android:id="@+id/tab2_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="@string/tab_category"
            android:src="@drawable/ic_home" />

        <TextView
            android:id="@+id/tab2_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/tab_category"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tab3"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="4dp">

        <ImageView
            android:id="@+id/tab3_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="@string/tab_add"
            android:src="@drawable/ic_home" />

        <TextView
            android:id="@+id/tab3_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/tab_add"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tab4"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="4dp">

        <ImageView
            android:id="@+id/tab4_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="@string/tab_chart"
            android:src="@drawable/ic_home" />

        <TextView
            android:id="@+id/tab4_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/tab_chart"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tab5"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="4dp">

        <ImageView
            android:id="@+id/tab5_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="@string/tab_mine"
            android:src="@drawable/ic_home" />

        <TextView
            android:id="@+id/tab5_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/tab_mine"
            android:textSize="12sp" />
    </LinearLayout>

</LinearLayout>
