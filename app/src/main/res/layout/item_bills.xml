<?xml version="1.0" encoding="utf-8"?>
<com.hjq.shape.layout.ShapeConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    app:shape_solidColor="@color/white"
    app:shape_strokeSize="1dp"
    app:shape_strokeColor="@color/line_deposit"
    app:shape_radius="10dp"
    android:paddingVertical="12dp"
    android:paddingHorizontal="15dp"
    android:layout_marginHorizontal="15dp">
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_color_black"
        android:textSize="15sp"
        android:textStyle="bold"
        tools:text="Deposit Commission"/>
    <TextView
        android:id="@+id/tv_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="@color/text_color_black"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        android:layout_marginTop="5dp"
        tools:text="00000"/>
    <androidx.constraintlayout.widget.Group
        android:id="@+id/group_utr"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:constraint_referenced_ids="tv_utr,iv_copy"/>
    <TextView
        android:id="@+id/tv_utr"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_color_black"
        android:textSize="13sp"
        app:layout_constraintTop_toBottomOf="@id/tv_date"
        android:layout_marginTop="5dp"
        tools:text="000000"/>
    <ImageView
        android:id="@+id/iv_copy"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@drawable/ic_copy"
        app:layout_constraintStart_toEndOf="@id/tv_utr"
        app:layout_constraintTop_toTopOf="@id/tv_utr"
        app:layout_constraintBottom_toBottomOf="@id/tv_utr"
        android:layout_marginStart="10sp"/>
    <TextView
        android:id="@+id/tv_amount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/amount_green"
        android:textSize="18sp"
        android:textStyle="bold"
        tools:text="+1000"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_point"/>
    <TextView
        android:id="@+id/tv_point"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/tv_amount"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:text="point"
        android:layout_marginTop="5dp"
        android:textSize="13sp"
        android:textColor="@color/text_color_gray"/>
</com.hjq.shape.layout.ShapeConstraintLayout>