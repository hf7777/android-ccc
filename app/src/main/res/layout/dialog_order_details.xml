<?xml version="1.0" encoding="utf-8"?>
<com.hjq.shape.layout.ShapeConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:shape_solidColor="@color/white"
    app:shape_radius="15dp"
    android:paddingHorizontal="15dp">
    <TextView
        android:id="@+id/tv_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_color_black"
        android:textSize="18sp"
        android:textStyle="bold"
        android:text="@string/order_details"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="15dp"/>

    <TextView
        android:id="@+id/tv_to_address_tip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_color_gray"
        android:textSize="12sp"
        android:text="@string/to_address"
        app:layout_constraintTop_toBottomOf="@id/tv_name"
        android:layout_marginTop="10dp"/>
    <TextView
        android:id="@+id/tv_to_address"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        tools:text="0"
        android:textSize="14sp"
        android:textColor="@color/text_color_black"
        android:maxLines="3"
        android:ellipsize="end"
        app:layout_constraintStart_toStartOf="@id/tv_to_address_tip"
        app:layout_constraintEnd_toStartOf="@id/iv_copy_address"
        app:layout_constraintTop_toBottomOf="@id/tv_to_address_tip"
        android:layout_marginTop="5dp"
        android:layout_marginEnd="8dp"/>
    <ImageView
        android:id="@+id/iv_copy_address"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@drawable/ic_copy"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_to_address"
        app:layout_constraintBottom_toBottomOf="@id/tv_to_address"/>
    <TextView
        android:id="@+id/tv_tx_hash_tip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_color_gray"
        android:textSize="12sp"
        android:text="@string/tx_hash"
        app:layout_constraintTop_toBottomOf="@id/tv_to_address"
        android:layout_marginTop="15dp"/>
    <TextView
        android:id="@+id/tv_tx_hash"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="-"
        android:textSize="14sp"
        android:textColor="@color/text_color_black"
        android:maxLines="3"
        android:ellipsize="end"
        app:layout_constraintStart_toStartOf="@id/tv_tx_hash_tip"
        app:layout_constraintEnd_toStartOf="@id/iv_copy_hash"
        app:layout_constraintTop_toBottomOf="@id/tv_tx_hash_tip"
        android:layout_marginTop="5dp"
        android:layout_marginEnd="8dp"/>
    <ImageView
        android:id="@+id/iv_copy_hash"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@drawable/ic_copy"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_tx_hash"
        app:layout_constraintBottom_toBottomOf="@id/tv_tx_hash"/>
    <TextView
        android:id="@+id/tv_amount_tip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_color_gray"
        android:textSize="12sp"
        android:text="@string/usdt_amount"
        app:layout_constraintTop_toBottomOf="@id/tv_tx_hash"
        android:layout_marginTop="15dp"/>
    <TextView
        android:id="@+id/tv_amount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="-"
        android:textSize="14sp"
        android:textColor="@color/text_color_black"
        app:layout_constraintStart_toStartOf="@id/tv_amount_tip"
        app:layout_constraintEnd_toStartOf="@id/iv_copy_amount"
        app:layout_constraintTop_toBottomOf="@id/tv_amount_tip"
        android:layout_marginTop="5dp"
        android:layout_marginEnd="8dp"/>
    <ImageView
        android:id="@+id/iv_copy_amount"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@drawable/ic_copy"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_amount"
        app:layout_constraintBottom_toBottomOf="@id/tv_amount"/>

    <com.hjq.shape.view.ShapeButton
        android:id="@+id/btn_close"
        style="@style/ButtonStyle"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        app:shape_solidColor="@color/white"
        android:paddingHorizontal="12dp"
        android:text="@string/close"
        android:textColor="@color/theme"
        android:layout_marginTop="15dp"
        android:layout_marginBottom="15dp"
        app:layout_constraintTop_toBottomOf="@id/tv_amount"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>
</com.hjq.shape.layout.ShapeConstraintLayout>
