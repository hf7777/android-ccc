<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/white">

    <com.hlc.lib_base.widget.TitleBar
        android:id="@+id/title_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:title="@string/tab_mine"
        app:showBack="false"
        app:layout_constraintTop_toTopOf="parent"/>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/refresh_layout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/title_bar"
        app:layout_constraintBottom_toBottomOf="parent">
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_user"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/iv_avatar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="20dp"
                    app:layout_constraintBottom_toBottomOf="parent"/>
                <TextView
                    android:id="@+id/tv_nickname"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    tools:text="Wade"
                    android:text="-"
                    android:textColor="@color/text_color_black"
                    app:layout_constraintTop_toTopOf="@id/iv_avatar"
                    app:layout_constraintStart_toEndOf="@id/iv_avatar"
                    android:layout_marginStart="10dp"/>
                <TextView
                    android:id="@+id/tv_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    tools:text="Hello"
                    android:text="-"
                    android:textColor="@color/text_color_black"
                    app:layout_constraintBottom_toBottomOf="@id/iv_avatar"
                    app:layout_constraintStart_toStartOf="@id/tv_nickname"/>
                <ImageView
                    android:id="@+id/iv_copy"
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/ic_copy"
                    app:layout_constraintTop_toTopOf="@id/tv_id"
                    app:layout_constraintBottom_toBottomOf="@id/tv_id"
                    app:layout_constraintStart_toEndOf="@id/tv_id"
                    android:layout_marginStart="5dp"/>
                <ImageView
                    android:layout_width="6dp"
                    android:layout_height="10dp"
                    android:src="@drawable/ic_arrow_right"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginEnd="20dp"/>
            </androidx.constraintlayout.widget.ConstraintLayout>


            <com.hjq.shape.layout.ShapeConstraintLayout
                android:id="@+id/cl_balance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/cl_user"
                app:shape_solidColor="@color/bg_mine_balance"
                app:shape_radius="15dp"
                android:layout_marginStart="15dp"
                android:layout_marginEnd="15dp">
                <TextView
                    android:id="@+id/tv_point"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_color_white"
                    android:text="@string/a_points"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:layout_marginStart="15dp"
                    android:layout_marginTop="16dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/text_color_white"
                    app:layout_constraintTop_toTopOf="@id/tv_point"
                    app:layout_constraintBottom_toBottomOf="@id/tv_point"
                    app:layout_constraintStart_toEndOf="@id/tv_point"
                    android:text="@string/_1_points_1_rs"/>
                <ImageView
                    android:id="@+id/iv_coin"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_coin"
                    app:layout_constraintStart_toStartOf="@id/tv_point"
                    app:layout_constraintTop_toBottomOf="@id/tv_point"
                    android:layout_marginTop="17dp"/>
                <TextView
                    android:id="@+id/tv_balance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="200"
                    android:textColor="@color/text_color_white"
                    android:textStyle="bold"
                    android:textSize="30sp"
                    android:layout_marginStart="5dp"
                    app:layout_constraintStart_toEndOf="@id/iv_coin"
                    app:layout_constraintTop_toTopOf="@id/iv_coin"
                    app:layout_constraintBottom_toBottomOf="@id/iv_coin"/>
                <TextView
                    android:id="@+id/tv_earnings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toBottomOf="@id/iv_coin"
                    android:layout_marginTop="14dp"
                    app:layout_constraintStart_toStartOf="@id/iv_coin"
                    android:textSize="15sp"
                    android:text="Today's earnings: 0"
                    tools:text="Today's earnings: 0"
                    android:textColor="@color/text_color_white"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginBottom="14dp"/>
                <com.hjq.shape.view.ShapeButton
                    android:id="@+id/btn_detail"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:gravity="center"
                    android:text="@string/detail"
                    android:textColor="@color/text_color_white"
                    android:textSize="14sp"
                    android:includeFontPadding="false"
                    app:shape_solidColor="@color/theme"
                    app:shape_radius="10dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginEnd="15dp"/>
            </com.hjq.shape.layout.ShapeConstraintLayout>
            <com.hjq.shape.layout.ShapeConstraintLayout
                android:id="@+id/cl_withdraw"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/cl_balance"
                app:shape_solidColor="@color/bg_mine_withdraw"
                app:shape_radius="15dp"
                android:layout_marginStart="15dp"
                android:layout_marginEnd="15dp"
                android:layout_marginTop="10dp">
                <TextView
                    android:id="@+id/tv_withdraw"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_color_white"
                    android:text="@string/withdraw"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:layout_marginStart="15dp"
                    android:layout_marginTop="16dp"/>
                <TextView
                    android:id="@+id/tv_in_transaction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="200"
                    android:text="0"
                    android:textColor="@color/text_color_white"
                    app:layout_constraintTop_toBottomOf="@id/tv_withdraw"
                    app:layout_constraintStart_toStartOf="@id/tv_withdraw"
                    android:layout_marginTop="11dp"/>
                <TextView
                    android:id="@+id/in_transaction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/in_transaction"
                    android:textSize="13sp"
                    android:textColor="@color/text_color_white"
                    app:layout_constraintStart_toStartOf="@id/tv_in_transaction"
                    app:layout_constraintTop_toBottomOf="@id/tv_in_transaction"
                    android:layout_marginTop="3dp"/>
                <TextView
                    android:id="@+id/tv_today_withdraw"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="200"
                    android:text="0"
                    android:textColor="@color/text_color_white"
                    android:layout_marginStart="65dp"
                    app:layout_constraintTop_toTopOf="@id/tv_in_transaction"
                    app:layout_constraintStart_toEndOf="@id/tv_withdraw"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/today_withdraw"
                    android:textSize="13sp"
                    android:textColor="@color/text_color_white"
                    app:layout_constraintStart_toStartOf="@id/tv_today_withdraw"
                    app:layout_constraintTop_toBottomOf="@id/tv_today_withdraw"
                    android:layout_marginTop="3dp"/>
                <TextView
                    android:id="@+id/tv_withdraw_upi_tool"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/text_color_white"
                    android:text="In withdraw UPl tool: 0"
                    app:layout_constraintTop_toBottomOf="@id/in_transaction"
                    app:layout_constraintStart_toStartOf="@id/in_transaction"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginBottom="14dp"
                    android:layout_marginTop="11dp"/>
                <com.hjq.shape.view.ShapeButton
                    android:id="@+id/btn_manage"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:gravity="center"
                    android:text="@string/manage"
                    android:textColor="@color/text_color_white"
                    android:textSize="14sp"
                    app:shape_solidColor="@color/theme"
                    app:shape_radius="10dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:layout_marginEnd="15dp"
                    android:layout_marginTop="15dp"/>
            </com.hjq.shape.layout.ShapeConstraintLayout>
            <com.hjq.shape.layout.ShapeConstraintLayout
                android:id="@+id/cl_deposit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/cl_withdraw"
                app:shape_solidColor="@color/bg_mine_deposit"
                app:shape_radius="15dp"
                android:layout_marginTop="10dp"
                android:layout_marginStart="15dp"
                android:layout_marginEnd="15dp">
                <TextView
                    android:id="@+id/tv_deposit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_color_white"
                    android:text="@string/deposit_buy_inr"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:layout_marginStart="15dp"
                    android:layout_marginTop="16dp"/>
                <TextView
                    android:id="@+id/tv_today_order"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="200"
                    android:text="0"
                    android:textColor="@color/text_color_white"
                    app:layout_constraintTop_toBottomOf="@id/tv_deposit"
                    app:layout_constraintStart_toStartOf="@id/tv_deposit"
                    android:layout_marginTop="11dp"/>
                <TextView
                    android:id="@+id/today_order"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/today_s_orders"
                    android:textSize="13sp"
                    android:textColor="@color/text_color_white"
                    app:layout_constraintStart_toStartOf="@id/tv_today_order"
                    app:layout_constraintTop_toBottomOf="@id/tv_today_order"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginBottom="14dp"
                    android:layout_marginTop="3dp"/>
                <TextView
                    android:id="@+id/tv_today_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="200"
                    android:text="0"
                    android:textColor="@color/text_color_white"
                    android:layout_marginStart="65dp"
                    app:layout_constraintTop_toTopOf="@id/tv_today_order"
                    app:layout_constraintStart_toEndOf="@id/tv_deposit"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/today_s_total"
                    android:textSize="13sp"
                    android:textColor="@color/text_color_white"
                    app:layout_constraintStart_toStartOf="@id/tv_today_total"
                    app:layout_constraintTop_toBottomOf="@id/tv_today_total"
                    android:layout_marginTop="3dp"/>

            </com.hjq.shape.layout.ShapeConstraintLayout>

            <TextView
                android:id="@+id/tv_common"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_color_black"
                android:text="@string/common_functions"
                app:layout_constraintTop_toBottomOf="@id/cl_deposit"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="15dp"
                android:layout_marginTop="20dp"/>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_common"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                app:layout_constraintTop_toBottomOf="@id/tv_common"
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="10dp"/>
            <TextView
                android:id="@+id/tv_other"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="@color/text_color_black"
                android:text="@string/other_functions"
                app:layout_constraintTop_toBottomOf="@id/rv_common"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="15dp"
                android:layout_marginEnd="15dp"
                android:layout_marginTop="20dp"/>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_other"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                app:layout_constraintTop_toBottomOf="@id/tv_other"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="50dp"
                app:layout_constraintBottom_toBottomOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
