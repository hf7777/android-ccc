<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:textSize="15sp"
        android:textColor="@color/text_color_black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="10dp"
        android:layout_marginStart="15dp"
        android:text="Bind Telegram Robot"/>
    <TextView
        android:id="@+id/tv_account"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_color_black"
        android:textSize="14sp"
        tools:text="00000"
        app:layout_constraintStart_toStartOf="@id/tv_title"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        android:layout_marginTop="3dp"/>
    <ImageView
        android:id="@+id/iv_copy"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@drawable/ic_copy"
        app:layout_constraintStart_toEndOf="@id/tv_account"
        app:layout_constraintTop_toTopOf="@id/tv_account"
        app:layout_constraintBottom_toBottomOf="@id/tv_account"
        android:layout_marginStart="3dp"/>
    <TextView
        android:id="@+id/tv_status_desc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/status_green"
        android:textSize="12sp"
        android:text="Newbie task completed"
        app:layout_constraintTop_toBottomOf="@id/tv_account"
        app:layout_constraintStart_toStartOf="@id/tv_account"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="10dp"
        android:layout_marginTop="3dp"/>
    <com.hjq.shape.view.ShapeButton
        android:id="@+id/btn_done"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="13dp"
        android:paddingVertical="6dp"
        android:text="Received"
        android:textSize="14sp"
        android:textColor="@color/text_color_white"
        android:textStyle="bold"
        app:shape_solidColor="@color/theme"
        app:shape_radius="9dp"
        app:shape_solidDisabledColor="@color/btn_disabled"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="15dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>