<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".feature.mine.BindTgActivity">
    <TextView
        android:id="@+id/tv_easy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/text_color_black"
        android:text="Easily receive OTP and order notifications"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="15dp"
        android:layout_marginTop="18dp"/>
    <com.hjq.shape.layout.ShapeConstraintLayout
        android:id="@+id/cl_bot_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        android:layout_marginTop="15dp"
        app:layout_constraintTop_toBottomOf="@id/tv_easy"
        app:shape_strokeColor="@color/edit_line"
        app:shape_strokeSize="1dp"
        app:shape_radius="10dp">
        <TextView
            android:id="@+id/tv_first"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/text_color_gray"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="15dp"
            android:layout_marginStart="10dp"
            android:text="@string/first_search_the_bot_on_telegram"/>
        <TextView
            android:id="@+id/tv_bot_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/theme"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/tv_first"
            app:layout_constraintTop_toBottomOf="@id/tv_first"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="20dp"
            android:layout_marginTop="25dp"
            tools:text="diugelga"/>
        <ImageView
            android:id="@+id/iv_copy_name"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_copy"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_bot_name"
            app:layout_constraintBottom_toBottomOf="@id/tv_bot_name"
            android:layout_marginEnd="15dp"/>
    </com.hjq.shape.layout.ShapeConstraintLayout>
    <com.hjq.shape.view.ShapeButton
        android:id="@+id/btn_open"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        app:shape_radius="10dp"
        app:shape_solidColor="@color/tg_color"
        app:layout_constraintTop_toBottomOf="@id/cl_bot_name"
        android:layout_marginTop="10dp"
        android:textColor="@color/text_color_white"
        android:textSize="13sp"
        android:gravity="center"
        android:textStyle="bold"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        android:text="@string/open_telegram"/>
    <com.hjq.shape.layout.ShapeConstraintLayout
        android:id="@+id/cl_bot_msg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/btn_open"
        app:shape_strokeColor="@color/edit_line"
        app:shape_strokeSize="1dp"
        app:shape_radius="10dp">
        <TextView
            android:id="@+id/tv_then_copy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/text_color_gray"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="15dp"
            android:layout_marginStart="10dp"
            android:text="Then copy the bind message and send it to the above bot:"/>
        <TextView
            android:id="@+id/tv_bind_msg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/theme"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/tv_then_copy"
            app:layout_constraintTop_toBottomOf="@id/tv_then_copy"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="20dp"
            android:layout_marginTop="25dp"
            tools:text="diugelga"/>
        <ImageView
            android:id="@+id/iv_copy_msg"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_copy"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_bind_msg"
            app:layout_constraintBottom_toBottomOf="@id/tv_bind_msg"
            android:layout_marginEnd="15dp"/>
    </com.hjq.shape.layout.ShapeConstraintLayout>
    <TextView
        android:id="@+id/tv_after_you"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/text_color_black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cl_bot_msg"
        android:layout_marginTop="30dp"
        android:gravity="center"
        android:text="@string/after_you_have_success_bind"/>
    <com.hjq.shape.view.ShapeButton
        android:id="@+id/btn_refresh"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        app:shape_radius="10dp"
        android:textStyle="bold"
        app:shape_solidColor="@color/theme"
        app:layout_constraintTop_toBottomOf="@id/tv_after_you"
        android:layout_marginTop="20dp"
        android:textColor="@color/text_color_white"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        android:text="@string/refresh"/>
</androidx.constraintlayout.widget.ConstraintLayout>