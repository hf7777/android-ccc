<?xml version="1.0" encoding="utf-8"?>
<com.hjq.shape.layout.ShapeConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:shape_solidColor="@color/white"
    app:shape_radiusInTopLeft="10dp"
    app:shape_radiusInTopRight="10dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:textSize="17sp"
        android:textColor="@color/text_color_black"
        android:text="@string/select_tool"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="15dp"/>
    <View
        android:id="@+id/line"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/item_line"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        android:layout_marginTop="12dp"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_wallet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/line"/>
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5"/>
    <com.hjq.shape.view.ShapeButton
        android:id="@+id/btn_cancel"
        android:layout_width="0dp"
        android:layout_height="51dp"
        android:text="@string/dialog_cancel"
        android:textSize="16sp"
        android:textColor="@color/text_color_black"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="@id/gl"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="10dp"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="10dp"
        android:gravity="center"
        app:shape_radius="10dp"
        app:shape_strokeSize="1dp"
        app:shape_strokeColor="@color/dialog_cancel_stroke"/>
    <com.hjq.shape.view.ShapeButton
        android:id="@+id/btn_confirm"
        android:layout_width="0dp"
        android:layout_height="51dp"
        android:text="@string/dialog_confirm"
        android:textSize="16sp"
        android:textColor="@color/text_color_white"
        android:textStyle="bold"
        app:shape_radius="10dp"
        app:shape_solidColor="@color/theme"
        app:layout_constraintStart_toStartOf="@id/gl"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="10dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="15dp"
        android:gravity="center"/>
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:text="@string/after_selecting_the_payment_tool"
        android:textColor="@color/wallet_tips"
        app:layout_constraintBottom_toTopOf="@id/btn_cancel"
        android:layout_marginHorizontal="15dp"
        android:layout_marginBottom="20dp"/>
</com.hjq.shape.layout.ShapeConstraintLayout>
