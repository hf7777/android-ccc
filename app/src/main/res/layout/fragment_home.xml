<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.hlc.lib_base.widget.TitleBar
        android:id="@+id/title_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:title="@string/tab_home"
        app:showBack="false"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <com.youth.banner.Banner
        android:id="@+id/banner"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title_bar"/>

    <TextView
        android:id="@+id/tv_point"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/text_color_black"
        android:text="@string/a_points"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="15dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/banner"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="@color/text_color_black"
        app:layout_constraintTop_toTopOf="@id/tv_point"
        app:layout_constraintBottom_toBottomOf="@id/tv_point"
        app:layout_constraintStart_toEndOf="@id/tv_point"
        android:text="1 Points = 1 Rs"/>
    <ImageView
        android:id="@+id/iv_coin"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@drawable/ic_coin"
        app:layout_constraintStart_toStartOf="@id/tv_point"
        app:layout_constraintTop_toBottomOf="@id/tv_point"
        android:layout_marginTop="19dp"/>
    <TextView
        android:id="@+id/tv_balance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_color_black"
        android:textSize="32sp"
        android:textStyle="bold"
        android:text="0"
        app:layout_constraintTop_toTopOf="@id/iv_coin"
        app:layout_constraintBottom_toBottomOf="@id/iv_coin"
        app:layout_constraintStart_toEndOf="@id/iv_coin"
        android:layout_marginStart="5dp"
        tools:text="200"/>

    <androidx.constraintlayout.widget.Guideline
        android:layout_width="1dp"
        android:layout_height="wrap_content"
        app:layout_constraintVertical_bias="0.5"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5"
        android:id="@+id/guideline"/>
    <com.hjq.shape.view.ShapeImageView
        android:id="@+id/iv_deposit"
        android:layout_width="0dp"
        android:layout_height="51dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="@id/guideline"
        android:layout_marginEnd="5dp"
        android:layout_marginStart="15dp"
        app:layout_constraintTop_toBottomOf="@id/tv_balance"
        app:shape_radius="10dp"
        app:shape_solidColor="@color/theme"
        android:src="@drawable/ic_deposit"
        android:layout_marginTop="10dp"
        android:padding="15dp"/>
    <com.hjq.shape.view.ShapeImageView
        android:id="@+id/iv_withdraw"
        android:layout_width="0dp"
        android:layout_height="51dp"
        app:layout_constraintStart_toStartOf="@id/guideline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_balance"
        android:layout_marginStart="5dp"
        android:layout_marginEnd="15dp"
        app:shape_radius="10dp"
        app:shape_solidColor="@color/bg_withdraw"
        android:src="@drawable/ic_withdraw"
        android:layout_marginTop="10dp"
        android:padding="15dp"/>
    <TextView
        android:id="@+id/tv_usdt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/deposit_a_points_with_usdt"
        app:layout_constraintStart_toStartOf="@id/iv_deposit"
        app:layout_constraintTop_toBottomOf="@id/iv_deposit"
        android:textStyle="bold"
        android:textSize="15sp"
        android:textColor="@color/text_color_black"
        android:layout_marginTop="20dp"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:text="@string/go_now"
        android:textColor="@color/theme"
        app:layout_constraintTop_toTopOf="@id/tv_usdt"
        app:layout_constraintBottom_toBottomOf="@id/tv_usdt"
        app:layout_constraintEnd_toEndOf="@id/iv_withdraw"/>

</androidx.constraintlayout.widget.ConstraintLayout>
