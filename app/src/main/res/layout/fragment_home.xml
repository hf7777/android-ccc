<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">


    <com.hlc.lib_base.widget.TitleBar
        android:id="@+id/title_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:title="@string/tab_home"
        app:showBack="false"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/refresh_layout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/title_bar"
        app:layout_constraintBottom_toBottomOf="parent">
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/title_bar">
            <com.youth.banner.Banner
                android:id="@+id/banner"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <TextView
                android:id="@+id/tv_point"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_color_black"
                android:text="@string/a_points"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="15dp"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/banner"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/text_color_black"
                app:layout_constraintTop_toTopOf="@id/tv_point"
                app:layout_constraintBottom_toBottomOf="@id/tv_point"
                app:layout_constraintStart_toEndOf="@id/tv_point"
                android:text="@string/_1_points_1_rs"/>
            <com.hjq.shape.view.ShapeTextView
                android:id="@+id/tv_balance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_color_black"
                android:textSize="32sp"
                android:textStyle="bold"
                android:text="0"
                android:gravity="center"
                app:layout_constraintStart_toStartOf="@id/tv_point"
                app:layout_constraintTop_toBottomOf="@id/tv_point"
                android:layout_marginTop="19dp"
                tools:text="200"/>

            <LinearLayout
                android:id="@+id/ll_balance_newbie"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="19dp"
                app:layout_constraintTop_toBottomOf="@id/tv_balance"
                app:layout_constraintStart_toStartOf="@id/tv_balance"
                android:visibility="gone">
                <com.hjq.shape.view.ShapeTextView
                    android:id="@+id/tv_balance_newbie"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textSize="32sp"
                    android:text="0"
                    android:textColor="@color/theme"
                    tools:text="200"
                    android:gravity="center"
                    app:shape_strokeColor="@color/theme"
                    app:shape_strokeSize="1dp"
                    app:shape_strokeDashSize="6dp"
                    app:shape_strokeDashGap="5dp"
                    app:shape_radius="5dp"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="2dp"/>
                <com.hjq.shape.view.ShapeTextView
                    android:id="@+id/tv_complete_tip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/complete_newbie_task_to_get_100_bonus"
                    app:shape_solidColor="@color/theme"
                    app:shape_radius="5dp"
                    android:layout_marginTop="10dp"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="3dp"
                    android:textColor="@color/text_color_white"/>
            </LinearLayout>

            <androidx.constraintlayout.widget.Guideline
                android:layout_width="1dp"
                android:layout_height="wrap_content"
                app:layout_constraintVertical_bias="0.5"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.5"
                android:id="@+id/guideline"/>
            <com.hjq.shape.layout.ShapeLinearLayout
                android:id="@+id/ll_deposit"
                android:layout_width="0dp"
                android:layout_height="51dp"
                android:orientation="horizontal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="@id/guideline"
                android:layout_marginEnd="5dp"
                android:layout_marginStart="15dp"
                app:layout_constraintTop_toBottomOf="@id/ll_balance_newbie"
                app:shape_radius="10dp"
                android:gravity="center"
                app:shape_solidColor="@color/theme"
                android:layout_marginTop="10dp">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_home_deposit"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_color_white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:text="@string/deposit"
                    android:layout_marginStart="4dp"/>
            </com.hjq.shape.layout.ShapeLinearLayout>
            <com.hjq.shape.layout.ShapeLinearLayout
                android:id="@+id/ll_withdraw"
                android:layout_width="0dp"
                android:layout_height="51dp"
                android:orientation="horizontal"
                app:layout_constraintStart_toStartOf="@id/guideline"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/ll_deposit"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="15dp"
                app:shape_radius="10dp"
                android:gravity="center"
                app:shape_solidColor="@color/bg_withdraw">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_home_withdraw"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_color_white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:text="@string/withdraw"
                    android:layout_marginStart="4dp"/>
            </com.hjq.shape.layout.ShapeLinearLayout>
            <TextView
                android:id="@+id/tv_usdt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/deposit_a_points_with_usdt"
                app:layout_constraintStart_toStartOf="@id/ll_deposit"
                app:layout_constraintTop_toBottomOf="@id/ll_deposit"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="@color/text_color_black"
                android:layout_marginTop="20dp"/>
            <TextView
                android:id="@+id/tv_usdt_go"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:text="@string/go_now"
                android:textColor="@color/theme"
                app:layout_constraintTop_toTopOf="@id/tv_usdt"
                app:layout_constraintBottom_toBottomOf="@id/tv_usdt"
                app:layout_constraintEnd_toEndOf="@id/ll_withdraw"/>

            <com.hjq.shape.layout.ShapeConstraintLayout
                android:id="@+id/cl_price"
                android:layout_width="match_parent"
                android:layout_height="106dp"
                android:layout_marginStart="15dp"
                android:layout_marginEnd="15dp"
                android:layout_marginTop="15dp"
                app:shape_solidColor="@color/bg_0f_theme"
                app:shape_radius="10dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_usdt">
                <View
                    android:id="@+id/por_line"
                    android:layout_width="1dp"
                    android:layout_height="52dp"
                    android:background="@color/line_deposit"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>
                <TextView
                    android:id="@+id/tv_market_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:text="0"
                    android:textColor="@color/text_market_price"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="@id/por_line"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/tv_mp"
                    app:layout_constraintVertical_chainStyle="packed"/>
                <TextView
                    android:id="@+id/tv_mp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/market_price"
                    android:textSize="13sp"
                    android:textColor="@color/text_market_price"
                    app:layout_constraintStart_toStartOf="@id/tv_market_price"
                    app:layout_constraintEnd_toEndOf="@id/tv_market_price"
                    app:layout_constraintTop_toBottomOf="@id/tv_market_price"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <TextView
                    android:id="@+id/tv_our_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:text="0"
                    android:textColor="@color/text_color_black"
                    app:layout_constraintStart_toStartOf="@id/por_line"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/tv_op"
                    app:layout_constraintVertical_chainStyle="packed"/>
                <TextView
                    android:id="@+id/tv_op"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/our_price"
                    android:textSize="13sp"
                    android:textColor="@color/text_color_black"
                    app:layout_constraintStart_toStartOf="@id/tv_our_price"
                    app:layout_constraintEnd_toEndOf="@id/tv_our_price"
                    app:layout_constraintTop_toBottomOf="@id/tv_our_price"
                    app:layout_constraintBottom_toBottomOf="parent"/>
            </com.hjq.shape.layout.ShapeConstraintLayout>


            <TextView
                android:id="@+id/tv_rupee"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/deposit_a_points_with_rupee"
                app:layout_constraintStart_toStartOf="@id/ll_deposit"
                app:layout_constraintTop_toBottomOf="@id/cl_price"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="@color/text_color_black"
                android:layout_marginTop="10dp"/>
            <TextView
                android:id="@+id/tv_rupee_go"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:text="@string/go_now"
                android:textColor="@color/theme"
                app:layout_constraintTop_toTopOf="@id/tv_rupee"
                app:layout_constraintBottom_toBottomOf="@id/tv_rupee"
                app:layout_constraintEnd_toEndOf="@id/ll_withdraw"/>

            <com.hjq.shape.layout.ShapeConstraintLayout
                android:id="@+id/cl_rupee"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginStart="15dp"
                android:layout_marginEnd="15dp"
                android:layout_marginTop="10dp"
                app:shape_solidColor="@color/bg_0f_theme"
                app:shape_radius="10dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_rupee">
                <ImageView
                    android:id="@+id/iv_rupee_hot"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_coin"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/tv_reward"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintHorizontal_chainStyle="packed"/>
                <TextView
                    android:id="@+id/tv_reward"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/theme"
                    android:textSize="20sp"
                    app:layout_constraintTop_toTopOf="@id/iv_rupee_hot"
                    app:layout_constraintBottom_toBottomOf="@id/iv_rupee_hot"
                    app:layout_constraintStart_toEndOf="@id/iv_rupee_hot"
                    android:layout_marginStart="5dp"
                    app:layout_constraintEnd_toEndOf="parent"/>
            </com.hjq.shape.layout.ShapeConstraintLayout>
            <TextView
                android:id="@+id/tv_tutorial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="@color/text_color_black"
                android:text="@string/tutorial"
                android:layout_marginTop="20dp"
                android:layout_marginStart="15dp"
                app:layout_constraintTop_toBottomOf="@id/cl_rupee"
                app:layout_constraintStart_toStartOf="parent"/>
            <TextView
                android:id="@+id/tv_learn_more"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/theme"
                android:textSize="14sp"
                android:text="@string/learn_more"
                app:layout_constraintTop_toTopOf="@id/tv_tutorial"
                app:layout_constraintBottom_toBottomOf="@id/tv_tutorial"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginEnd="15dp"/>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_tutorial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/tv_tutorial"
                android:scrollbars="none"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
