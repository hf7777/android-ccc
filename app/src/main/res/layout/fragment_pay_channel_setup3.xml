<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:paddingHorizontal="15dp"
    android:orientation="vertical"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <TextView
                android:id="@+id/tv_great"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="@color/text_color_black"
                android:text="@string/you_are_doing_great"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="15dp"/>
            <TextView
                android:id="@+id/tv_tips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/tv_great"
                app:layout_constraintStart_toStartOf="@id/tv_great"
                android:textColor="@color/text_color_black"
                android:textSize="15sp"
                android:text="@string/_1_please_select_your_preferred_upi"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="8dp"/>
            <TextView
                android:id="@+id/tv_upi_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/upi"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_color_black"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_tips"
                android:layout_marginTop="16dp"/>
            <com.hjq.shape.view.ShapeTextView
                android:id="@+id/tv_upi"
                android:layout_width="match_parent"
                android:layout_height="51dp"
                app:shape_radius="10dp"
                android:textSize="15sp"
                android:textColor="@color/text_color_black"
                android:singleLine="true"
                app:layout_constraintTop_toBottomOf="@id/tv_upi_title"
                android:layout_marginTop="9dp"
                app:shape_strokeSize="1dp"
                app:shape_strokeColor="@color/edit_stroke_normal"
                android:gravity="center_vertical"
                android:paddingHorizontal="15dp"/>
            <ImageView
                android:layout_width="6dp"
                android:layout_height="9dp"
                android:src="@drawable/ic_arrow_down"
                app:layout_constraintEnd_toEndOf="@id/tv_upi"
                android:layout_marginEnd="15dp"
                app:layout_constraintTop_toTopOf="@id/tv_upi"
                app:layout_constraintBottom_toBottomOf="@id/tv_upi"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
    <com.hjq.shape.view.ShapeButton
        android:id="@+id/btn_finish"
        style="@style/ButtonStyle"
        android:text="@string/finish"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="20dp"
        android:enabled="false"
        app:shape_solidDisabledColor="@color/btn_disabled"/>
</LinearLayout>