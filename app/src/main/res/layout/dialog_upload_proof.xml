<?xml version="1.0" encoding="utf-8"?>
<com.hjq.shape.layout.ShapeLinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingTop="20dp"
    android:paddingBottom="20dp"
    app:shape_radius="16dp"
    app:shape_solidColor="@color/white">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/upload_proof"
            android:textColor="@color/text_color_black"
            android:textSize="22sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/iv_close"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_dialog_close" />
    </RelativeLayout>

    <TextView
        android:id="@+id/tv_utr_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/txid"
        android:textColor="@color/text_color_black"
        android:textSize="14sp" />

    <com.hjq.shape.view.ShapeEditText
        android:id="@+id/et_utr"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:hint="@string/please_enter_transaction_id"
        android:paddingHorizontal="16dp"
        android:singleLine="true"
        android:textColor="@color/text_color_black"
        android:textColorHint="@color/edit_hint"
        android:textSize="15sp"
        android:inputType="number"
        android:maxLength="12"
        app:shape_radius="10dp"
        app:shape_strokeColor="@color/edit_stroke_normal"
        app:shape_strokeSize="1dp" />

    <TextView
        android:id="@+id/tv_upload_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/please_upload_transaction_screenshot"
        android:textColor="@color/text_color_black"
        android:textSize="14sp" />

    <com.hjq.shape.layout.ShapeConstraintLayout
        android:id="@+id/cl_select_image"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_marginTop="12dp"
        android:clickable="true"
        android:focusable="true"
        android:padding="16dp"
        app:shape_radius="12dp"
        app:shape_solidColor="@color/bg_0f_theme"
        app:shape_strokeColor="@color/theme_transparent_30"
        app:shape_strokeSize="1dp">

        <ImageView
            android:id="@+id/iv_proof_preview"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/layout_image_placeholder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/iv_placeholder"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_gallery"
                android:tint="@color/text_color_gray" />

            <TextView
                android:id="@+id/tv_select_image_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/tap_to_select_image"
                android:textColor="@color/text_color_gray"
                android:textSize="16sp" />
        </LinearLayout>
    </com.hjq.shape.layout.ShapeConstraintLayout>

    <com.hjq.shape.view.ShapeButton
        android:id="@+id/btn_submit"
        style="@style/ButtonStyle"
        android:layout_marginTop="22dp"
        android:enabled="false"
        android:text="@string/submit"
        app:shape_solidDisabledColor="@color/btn_disabled" />

</com.hjq.shape.layout.ShapeLinearLayout>
