<?xml version="1.0" encoding="utf-8"?>
<com.hjq.shape.layout.ShapeConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:paddingHorizontal="12dp"
    app:shape_radius="10dp"
    app:shape_strokeColor="@color/item_line"
    app:shape_strokeSize="1dp"
    app:shape_solidColor="@color/white"
    android:layout_marginHorizontal="15dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <ImageView
        android:id="@+id/iv_deposit"
        android:layout_width="15dp"
        android:layout_height="15dp"
        android:src="@drawable/ic_deposit_order"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="15dp"/>
    <TextView
        android:id="@+id/tv_order_no"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        tools:text="NNNNNN"
        android:textColor="@color/text_color_black"
        app:layout_constraintTop_toTopOf="@id/iv_deposit"
        app:layout_constraintBottom_toBottomOf="@id/iv_deposit"
        app:layout_constraintStart_toEndOf="@id/iv_deposit"
        android:layout_marginStart="3dp"/>
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/text_color_gray"
        app:layout_constraintTop_toTopOf="@id/iv_deposit"
        app:layout_constraintBottom_toBottomOf="@id/iv_deposit"
        app:layout_constraintEnd_toEndOf="parent"/>
    <TextView
        android:id="@+id/tv_payment_amount_tip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        app:layout_constraintTop_toBottomOf="@id/iv_deposit"
        android:layout_marginTop="17dp"
        android:textColor="@color/text_color_black"
        android:text="@string/payment_amount"/>
    <TextView
        android:id="@+id/tv_payment_amount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        app:layout_constraintTop_toTopOf="@id/tv_payment_amount_tip"
        app:layout_constraintBottom_toBottomOf="@id/tv_payment_amount_tip"
        app:layout_constraintEnd_toEndOf="parent"
        android:textColor="@color/text_color_black"
        tools:text="0"/>

    <TextView
        android:id="@+id/tv_deposit_tip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        app:layout_constraintTop_toBottomOf="@id/tv_payment_amount_tip"
        android:layout_marginTop="10dp"
        android:textColor="@color/text_color_black"
        android:text="@string/deposit"/>
    <TextView
        android:id="@+id/tv_deposit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        app:layout_constraintTop_toTopOf="@id/tv_deposit_tip"
        app:layout_constraintBottom_toBottomOf="@id/tv_deposit_tip"
        app:layout_constraintEnd_toEndOf="parent"
        android:textColor="@color/text_color_black"
        tools:text="0"/>

    <TextView
        android:id="@+id/tv_time_tip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        app:layout_constraintTop_toBottomOf="@id/tv_deposit_tip"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="12dp"
        android:layout_marginTop="10dp"
        android:textColor="@color/text_color_black"
        android:text="@string/created_time"/>
    <TextView
        android:id="@+id/tv_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        app:layout_constraintTop_toTopOf="@id/tv_time_tip"
        app:layout_constraintBottom_toBottomOf="@id/tv_time_tip"
        app:layout_constraintEnd_toEndOf="parent"
        android:textColor="@color/text_color_black"
        tools:text="0"/>
</com.hjq.shape.layout.ShapeConstraintLayout>