<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingHorizontal="15dp"
    android:background="@color/white"
    tools:context=".feature.wallet.EditUpiActivity">
    <TextView
        android:id="@+id/tv_partner_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/partner"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/text_color_black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="16dp"/>
    <com.hjq.shape.view.ShapeTextView
        android:id="@+id/tv_partner"
        android:layout_width="match_parent"
        android:layout_height="51dp"
        app:shape_radius="10dp"
        android:textSize="15sp"
        android:textColor="@color/text_color_black"
        android:singleLine="true"
        app:layout_constraintTop_toBottomOf="@id/tv_partner_title"
        android:layout_marginTop="9dp"
        app:shape_strokeSize="1dp"
        app:shape_strokeColor="@color/edit_stroke_normal"
        android:gravity="center_vertical"
        android:paddingHorizontal="15dp"/>
    <TextView
        android:id="@+id/tv_account_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/account"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/text_color_black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_partner"
        android:layout_marginTop="11dp"/>
    <com.hjq.shape.view.ShapeTextView
        android:id="@+id/tv_account"
        android:layout_width="match_parent"
        android:layout_height="51dp"
        app:shape_radius="10dp"
        android:textSize="15sp"
        android:textColor="@color/text_color_black"
        app:layout_constraintTop_toBottomOf="@id/tv_account_title"
        android:layout_marginTop="9dp"
        android:singleLine="true"
        app:shape_strokeSize="1dp"
        app:shape_strokeColor="@color/edit_stroke_normal"
        android:gravity="center_vertical"
        android:paddingHorizontal="15dp"/>
    <TextView
        android:id="@+id/tv_upi_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/upi"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/text_color_black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_account"
        android:layout_marginTop="11dp"/>
    <com.hjq.shape.view.ShapeTextView
        android:id="@+id/tv_upi"
        android:layout_width="match_parent"
        android:layout_height="51dp"
        app:shape_radius="10dp"
        android:textSize="15sp"
        android:textColor="@color/text_color_black"
        app:layout_constraintTop_toBottomOf="@id/tv_upi_title"
        android:layout_marginTop="9dp"
        android:singleLine="true"
        app:shape_strokeSize="1dp"
        app:shape_strokeColor="@color/edit_stroke_normal"
        android:gravity="center_vertical"
        android:paddingHorizontal="15dp"/>
    <ImageView
        android:layout_width="6dp"
        android:layout_height="9dp"
        android:src="@drawable/ic_arrow_down"
        app:layout_constraintEnd_toEndOf="@id/tv_upi"
        android:layout_marginEnd="15dp"
        app:layout_constraintTop_toTopOf="@id/tv_upi"
        app:layout_constraintBottom_toBottomOf="@id/tv_upi"/>

    <com.hjq.shape.view.ShapeButton
        android:id="@+id/btn_confirm"
        style="@style/ButtonStyle"
        android:text="@string/confirm"
        app:layout_constraintTop_toBottomOf="@id/tv_upi"
        android:layout_marginTop="35dp"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/wallet_tips"
        android:lineSpacingExtra="3dp"
        android:textSize="14sp"
        android:text="@string/if_you_want_to_choose_a_new_upi"
        app:layout_constraintTop_toBottomOf="@id/btn_confirm"
        android:layout_marginTop="15dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>