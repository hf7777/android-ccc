<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:scrollbars="none"
    android:background="@color/bg_page"
    tools:context=".feature.mine.withdraw.WithdrawActivity">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <com.hjq.shape.view.ShapeButton
            android:id="@+id/btn_add_bank"
            style="@style/ButtonStyle"
            android:layout_marginHorizontal="15dp"
            android:text="@string/add_bank"
            android:visibility="gone"
            tools:visibility="visible"
            android:layout_marginTop="15dp"/>
        <com.hjq.shape.layout.ShapeConstraintLayout
            android:id="@+id/cl_bank_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="15dp"
            android:layout_marginTop="15dp"
            app:shape_solidColor="@color/white"
            android:visibility="gone"
            tools:visibility="visible"
            app:shape_radius="10dp">
            <ImageView
                android:id="@+id/iv_bank"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_bank"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="20dp"
                android:layout_marginTop="15dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_color_black"
                android:textSize="16sp"
                android:text="Settlement\nAccount"
                app:layout_constraintStart_toEndOf="@id/iv_bank"
                app:layout_constraintTop_toTopOf="@id/iv_bank"
                app:layout_constraintBottom_toBottomOf="@id/iv_bank"
                android:layout_marginStart="10dp"
                android:textStyle="bold"/>
            <com.hjq.shape.view.ShapeImageView
                android:id="@+id/iv_edit"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_edit"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/iv_bank"
                app:layout_constraintBottom_toBottomOf="@id/iv_bank"
                android:layout_marginEnd="25dp"
                app:shape_solidColor="@color/theme_transparent_30"
                app:shape_type="oval"
                android:padding="6dp"/>
            <TextView
                android:id="@+id/tv_account_name_tip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_color_gray"
                android:text="@string/account_name"
                android:textSize="11sp"
                app:layout_constraintTop_toBottomOf="@id/iv_bank"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="@id/iv_bank"/>
            <TextView
                android:id="@+id/tv_account_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="@color/text_color_black"
                app:layout_constraintTop_toBottomOf="@id/tv_account_name_tip"
                app:layout_constraintStart_toStartOf="@id/tv_account_name_tip"
                android:layout_marginTop="4dp"
                tools:text="Federal"/>
            <TextView
                android:id="@+id/tv_account_number_tip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_color_gray"
                android:text="@string/account_number"
                android:textSize="11sp"
                app:layout_constraintTop_toBottomOf="@id/tv_account_name"
                android:layout_marginTop="10dp"
                app:layout_constraintStart_toStartOf="@id/iv_bank"/>
            <TextView
                android:id="@+id/tv_account_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="@color/text_color_black"
                app:layout_constraintTop_toBottomOf="@id/tv_account_number_tip"
                app:layout_constraintStart_toStartOf="@id/tv_account_number_tip"
                android:layout_marginTop="4dp"
                tools:text="Federal"/>
            <TextView
                android:id="@+id/tv_bene_tip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_color_gray"
                android:text="@string/beneficiary_name"
                android:textSize="11sp"
                app:layout_constraintTop_toBottomOf="@id/tv_account_number"
                android:layout_marginTop="10dp"
                app:layout_constraintStart_toStartOf="@id/iv_bank"/>
            <TextView
                android:id="@+id/tv_bene"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="@color/text_color_black"
                app:layout_constraintTop_toBottomOf="@id/tv_bene_tip"
                app:layout_constraintStart_toStartOf="@id/tv_bene_tip"
                android:layout_marginTop="4dp"
                tools:text="Federal"/>
            <TextView
                android:id="@+id/tv_ifsc_tip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_color_gray"
                android:text="@string/ifsc"
                android:textSize="11sp"
                app:layout_constraintTop_toBottomOf="@id/tv_bene"
                android:layout_marginTop="10dp"
                app:layout_constraintStart_toStartOf="@id/iv_bank"/>
            <TextView
                android:id="@+id/tv_ifsc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="@color/text_color_black"
                app:layout_constraintTop_toBottomOf="@id/tv_ifsc_tip"
                app:layout_constraintStart_toStartOf="@id/tv_ifsc_tip"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginBottom="20dp"
                android:layout_marginTop="4dp"
                tools:text="Federal"/>
        </com.hjq.shape.layout.ShapeConstraintLayout>
        <com.hjq.shape.layout.ShapeConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginHorizontal="15dp"
            app:shape_radius="10dp"
            android:layout_marginTop="10dp"
            app:shape_solidColor="@color/white">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/text_color_black"
                android:text="@string/withdrawable_balance"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="20dp"/>
            <TextView
                android:id="@+id/tv_balance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/text_color_black"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginEnd="15dp"
                tools:text="@string/price_symbol"/>
        </com.hjq.shape.layout.ShapeConstraintLayout>
        <com.hjq.shape.layout.ShapeConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="15dp"
            app:shape_radius="10dp"
            app:shape_solidColor="@color/white"
            android:layout_marginHorizontal="15dp">
            <com.hjq.shape.view.ShapeView
                android:id="@+id/dot"
                android:layout_width="5dp"
                android:layout_height="5dp"
                app:shape_solidColor="@color/theme"
                app:shape_type="oval"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"/>
            <TextView
                android:id="@+id/tv_trading_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_color_black"
                android:textSize="15sp"
                app:layout_constraintTop_toTopOf="@id/dot"
                app:layout_constraintBottom_toBottomOf="@id/dot"
                app:layout_constraintStart_toEndOf="@id/dot"
                android:layout_marginStart="5dp"
                android:text="Auto Trading: Stopped"/>
            <TextView
                android:id="@+id/tv_trading_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/text_color_gray"
                app:layout_constraintStart_toStartOf="@id/dot"
                app:layout_constraintTop_toBottomOf="@id/tv_trading_status"
                android:layout_marginTop="5dp"
                tools:text="Can restart in 0 hours"/>
            <com.hjq.shape.view.ShapeButton
                android:id="@+id/btn_auto_trading"
                style="@style/ButtonStyle"
                android:layout_marginHorizontal="20dp"
                android:text="@string/restart_auto_trading"
                app:layout_constraintTop_toBottomOf="@id/tv_trading_time"
                android:layout_marginTop="15dp"
                app:shape_radius="30dp"
                android:textSize="13sp"
                android:layout_height="38dp"
                app:shape_solidDisabledColor="@color/btn_disabled"/>
            <com.hjq.shape.layout.ShapeConstraintLayout
                android:id="@+id/cl_monthly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="15dp"
                app:shape_solidColor="@color/bg_page"
                app:layout_constraintTop_toBottomOf="@id/btn_auto_trading"
                android:layout_marginTop="15dp"
                app:shape_radius="10dp">
                <TextView
                    android:id="@+id/tv_monthly"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/theme"
                    android:textSize="13sp"
                    android:text="Monthly Withdrawals"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="10dp"/>
                <TextView
                    android:id="@+id/tv_remaining"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_color_gray"
                    android:textSize="13sp"
                    android:text="Remain this month:"
                    app:layout_constraintTop_toBottomOf="@id/tv_monthly"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_marginStart="10dp"
                    app:layout_constraintBottom_toBottomOf="parent"/>
                <TextView
                    android:id="@+id/tv_used"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/theme"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="@id/tv_monthly"
                    app:layout_constraintBottom_toBottomOf="@id/tv_monthly"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginEnd="10dp"
                    tools:text="0/4 used"/>
                <TextView
                    android:id="@+id/tv_remaining_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textColor="@color/status_green"
                    app:layout_constraintTop_toTopOf="@id/tv_remaining"
                    app:layout_constraintBottom_toBottomOf="@id/tv_remaining"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginEnd="10dp"
                    tools:text="4"/>
            </com.hjq.shape.layout.ShapeConstraintLayout>

            <com.hjq.shape.view.ShapeView
                android:id="@+id/dot_2"
                android:layout_width="5dp"
                android:layout_height="5dp"
                app:shape_solidColor="@color/theme"
                app:shape_type="oval"
                app:layout_constraintTop_toBottomOf="@id/cl_monthly"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="15dp"
                android:layout_marginTop="20dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_color_black"
                android:textSize="15sp"
                app:layout_constraintTop_toTopOf="@id/dot_2"
                app:layout_constraintBottom_toBottomOf="@id/dot_2"
                app:layout_constraintStart_toEndOf="@id/dot_2"
                android:layout_marginStart="5dp"
                android:text="@string/withdraw_funds"/>
            <com.hjq.shape.view.ShapeEditText
                android:id="@+id/et_amount"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:inputType="number"
                app:shape_radius="10dp"
                app:shape_strokeColor="@color/edit_stroke_normal"
                app:shape_solidDisabledColor="@color/btn_disabled"
                android:layout_marginHorizontal="15dp"
                android:hint="Enter Withdrawal Amount(₹)"
                app:layout_constraintTop_toBottomOf="@id/dot_2"
                android:layout_marginTop="15dp"
                android:textSize="13sp"
                android:textColor="@color/text_color_black"
                android:textColorHint="@color/edit_hint"
                app:shape_strokeSize="1dp"
                android:paddingHorizontal="10dp"/>
            <TextView
                android:id="@+id/tv_min_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_color_gray"
                android:textSize="13sp"
                app:layout_constraintTop_toBottomOf="@id/et_amount"
                android:layout_marginTop="10dp"
                android:text="Minimum amount: ₹0"
                app:layout_constraintStart_toStartOf="@id/et_amount"/>
            <com.hjq.shape.view.ShapeButton
                android:id="@+id/btn_submit"
                style="@style/ButtonStyle"
                android:layout_marginHorizontal="20dp"
                android:text="@string/submit_withdrawal"
                app:layout_constraintTop_toBottomOf="@id/tv_min_amount"
                android:layout_marginTop="20dp"
                app:shape_radius="30dp"
                android:textSize="13sp"
                android:layout_height="38dp"
                app:shape_solidDisabledColor="@color/btn_disabled"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginBottom="20dp"/>
        </com.hjq.shape.layout.ShapeConstraintLayout>
        <TextView
            android:id="@+id/tv_record"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/view_withdrawal_records"
            android:textColor="@color/theme"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="80dp"
            android:textSize="15sp"
            android:textStyle="bold"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>