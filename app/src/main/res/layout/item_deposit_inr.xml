<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    <com.hjq.shape.view.ShapeTextView
        android:id="@+id/tv_symbol"
        android:layout_width="37dp"
        android:layout_height="37dp"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        app:shape_solidColor="@color/theme"
        app:shape_type="oval"
        android:textColor="@color/text_color_white"
        android:includeFontPadding="false"
        android:text="@string/price_symbol"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="12dp"
        android:layout_marginStart="15dp"/>
    <TextView
        android:id="@+id/tv_price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="@id/tv_symbol"
        app:layout_constraintStart_toEndOf="@id/tv_symbol"
        android:layout_marginStart="12dp"
        android:textColor="@color/text_color_black"
        android:textStyle="bold"
        android:textSize="16sp"
        tools:text="1000Rs"/>
    <com.hjq.shape.view.ShapeTextView
        android:id="@+id/tv_bank"
        android:layout_width="wrap_content"
        android:layout_height="19dp"
        android:gravity="center"
        android:text="@string/bank"
        android:textSize="10sp"
        android:textColor="@color/text_color_black"
        app:shape_strokeSize="0.5dp"
        app:shape_strokeColor="@color/bank_stroke"
        app:layout_constraintTop_toBottomOf="@id/tv_price"
        android:layout_marginTop="2dp"
        android:paddingHorizontal="3dp"
        app:layout_constraintStart_toStartOf="@id/tv_price"/>
    <com.hjq.shape.view.ShapeButton
        android:id="@+id/btn_buy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="15dp"
        android:text="@string/buy"
        android:textColor="@color/text_color_white"
        android:textSize="14sp"
        android:textStyle="bold"
        app:shape_solidColor="@color/theme"
        app:shape_radius="10dp"
        android:paddingVertical="6dp"
        android:paddingHorizontal="20dp"
        android:includeFontPadding="false"/>
    <TextView
        android:id="@+id/tv_reward_tip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="@color/text_color_gray"
        android:text="@string/reward"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_symbol"
        android:layout_marginStart="31dp"
        android:layout_marginTop="11dp"/>
    <TextView
        android:id="@+id/tv_reward"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        tools:text="0"
        android:textColor="@color/text_color_black"
        app:layout_constraintTop_toBottomOf="@id/tv_reward_tip"
        app:layout_constraintStart_toStartOf="@id/tv_reward_tip"/>
    <TextView
        android:id="@+id/tv_commission"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/highlight_yellow"
        tools:text="0"
        android:textSize="16sp"
        app:layout_constraintTop_toTopOf="@id/tv_reward"
        app:layout_constraintBottom_toBottomOf="@id/tv_reward"
        app:layout_constraintStart_toEndOf="@id/tv_reward"
        android:layout_marginStart="5dp"/>
    <LinearLayout
        android:id="@+id/ll_in_coin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="@id/tv_reward_tip"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="15dp"
        android:orientation="vertical">
        <TextView
            android:id="@+id/tv_in_coin_tip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/text_color_gray"
            android:text="@string/incoin"/>
        <TextView
            android:id="@+id/tv_in_coin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="@color/text_color_black"
            tools:text="0"/>
    </LinearLayout>
    <View
        android:id="@+id/line"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/line_deposit"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="15dp"
        app:layout_constraintTop_toBottomOf="@id/ll_in_coin"/>

</androidx.constraintlayout.widget.ConstraintLayout>