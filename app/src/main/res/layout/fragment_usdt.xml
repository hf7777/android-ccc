<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingHorizontal="15dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".feature.deposit.USDTFragment">

    <TextView
        android:id="@+id/tv_network"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textColor="@color/text_color_black"
        android:textStyle="bold"
        android:text="@string/network"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="20dp"/>
    <com.hjq.shape.layout.ShapeLinearLayout
        android:id="@+id/ll_network"
        android:layout_width="match_parent"
        android:layout_height="51dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:shape_strokeColor="@color/theme"
        app:shape_radius="10dp"
        app:shape_strokeSize="1dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_network"
        android:layout_marginTop="10dp">
        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_net_trc"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/trc20"
            android:textSize="15sp"
            android:textColor="@color/text_color_black"
            android:layout_marginStart="5dp"/>
    </com.hjq.shape.layout.ShapeLinearLayout>

    <com.hjq.shape.view.ShapeView
        android:id="@+id/dot1"
        android:layout_width="5dp"
        android:layout_height="5dp"
        app:shape_type="oval"
        app:shape_solidColor="@color/theme"
        app:layout_constraintTop_toBottomOf="@id/ll_network"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="12dp"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/only_accept_trc20_network"
        android:textColor="@color/text_color_black"
        android:textSize="13sp"
        app:layout_constraintTop_toTopOf="@id/dot1"
        app:layout_constraintBottom_toBottomOf="@id/dot1"
        app:layout_constraintStart_toEndOf="@id/dot1"
        android:layout_marginStart="12dp"/>

    <TextView
        android:id="@+id/tv_your_transfer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textColor="@color/text_color_black"
        android:textStyle="bold"
        android:text="@string/you_transfer"
        app:layout_constraintTop_toBottomOf="@id/dot1"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"/>
    <com.hjq.shape.view.ShapeEditText
        android:id="@+id/et_usdt"
        android:layout_width="match_parent"
        android:layout_height="51dp"
        app:shape_strokeSize="1dp"
        app:shape_strokeColor="@color/theme"
        app:shape_radius="10dp"
        android:textSize="15sp"
        android:inputType="number"
        android:singleLine="true"
        android:maxLength="5"
        android:textColor="@color/text_color_black"
        android:hint="@string/please_enter_the_number"
        android:textColorHint="@color/text_color_gray"
        app:layout_constraintTop_toBottomOf="@id/tv_your_transfer"
        android:layout_marginTop="10dp"
        android:paddingStart="15dp"
        android:paddingEnd="60dp"
        android:gravity="center_vertical"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textColor="@color/text_color_black"
        android:textStyle="bold"
        android:text="@string/usdt"
        app:layout_constraintTop_toTopOf="@id/et_usdt"
        app:layout_constraintBottom_toBottomOf="@id/et_usdt"
        app:layout_constraintEnd_toEndOf="@id/et_usdt"
        android:layout_marginEnd="15dp"/>
    <com.hjq.shape.view.ShapeView
        android:id="@+id/dot2"
        android:layout_width="5dp"
        android:layout_height="5dp"
        app:shape_solidColor="@color/theme"
        app:shape_type="oval"
        app:layout_constraintTop_toBottomOf="@id/et_usdt"
        android:layout_marginTop="12dp"
        app:layout_constraintStart_toStartOf="parent"/>
    <TextView
        android:id="@+id/tv_range"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="@color/text_color_black"
        android:text="@string/the_input_range_usdt"
        android:gravity="start"
        app:layout_constraintTop_toBottomOf="@id/et_usdt"
        app:layout_constraintStart_toEndOf="@id/dot2"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="12dp"
        android:layout_marginTop="6dp"/>
    <com.hjq.shape.view.ShapeView
        android:id="@+id/dot3"
        android:layout_width="5dp"
        android:layout_height="5dp"
        app:shape_solidColor="@color/theme"
        app:shape_type="oval"
        app:layout_constraintTop_toBottomOf="@id/tv_range"
        android:layout_marginTop="14dp"
        app:layout_constraintStart_toStartOf="parent"/>
    <TextView
        android:id="@+id/tv_if_have_transaction"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="@color/text_color_black"
        android:text="@string/if_have_transaction_fee_don_t_forget_to_add_it_thetransfer_amount_must_match_the_sell_amount"
        android:gravity="start"
        app:layout_constraintTop_toBottomOf="@id/tv_range"
        app:layout_constraintStart_toStartOf="@id/tv_range"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="6dp"/>

    <TextView
        android:id="@+id/tv_you_deposit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textColor="@color/text_color_black"
        android:textStyle="bold"
        android:text="@string/you_deposit"
        app:layout_constraintTop_toBottomOf="@id/tv_if_have_transaction"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"/>

    <com.hjq.shape.view.ShapeTextView
        android:id="@+id/tv_deposit"
        android:layout_width="match_parent"
        android:layout_height="51dp"
        app:shape_radius="10dp"
        app:shape_strokeColor="@color/theme"
        app:shape_strokeSize="1dp"
        android:textColor="@color/text_color_black"
        android:textSize="15sp"
        android:textStyle="bold"
        android:text="0"
        android:paddingStart="15dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/tv_you_deposit"
        android:layout_marginTop="10dp"/>
    <ImageView
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@drawable/ic_coin"
        app:layout_constraintTop_toTopOf="@id/tv_deposit"
        app:layout_constraintBottom_toBottomOf="@id/tv_deposit"
        app:layout_constraintEnd_toEndOf="@id/tv_deposit"
        android:layout_marginEnd="15dp"/>
    
    <com.hjq.shape.view.ShapeButton
        android:id="@+id/btn_next"
        android:layout_width="match_parent"
        android:layout_height="51dp"
        app:shape_solidColor="@color/theme"
        app:shape_radius="10dp"
        android:text="@string/next"
        android:textColor="@color/text_color_white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tv_deposit"
        android:layout_marginTop="30dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>