<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MyWallet" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/theme</item>
        <item name="colorPrimaryVariant">@color/theme_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/theme</item>
        <item name="colorSecondaryVariant">@color/theme_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        
        <!-- Accent color (强调色) -->
        <item name="colorAccent">@color/theme</item>
        
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/theme</item>
        
        <!-- Background colors -->
        <item name="android:colorBackground">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>
        <item name="android:windowAnimationStyle">@style/ActivityAnimation</item>
        <!-- 配合 AutoSize，保证 EditText 可正常唤起输入法 -->
        <item name="android:windowSoftInputMode">adjustResize</item>

    </style>

    <style name="Theme.MyWallet" parent="Base.Theme.MyWallet" />

    <style name="ActivityAnimation">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>

    <style name="Theme.Splash" parent="Base.Theme.MyWallet">
        <item name="android:windowBackground">@drawable/splash_bg</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="ButtonStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/text_color_white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
        <item name="shape_solidColor">@color/theme</item>
        <item name="shape_radius">10dp</item>
    </style>
</resources>
