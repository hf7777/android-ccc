<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <queries>
        <package android:name="com.freecharge.android" />
        <package android:name="com.mobikwik_new" />
        <package android:name="com.s.autoactiveotpaa" />
        <package android:name="org.telegram.messenger" />
        <package android:name="com.whatsapp" />
        <package android:name="com.facebook.orca" />
        <package android:name="com.facebook.katana" />

        <intent>
            <action android:name="android.intent.action.SEND" />

            <data android:mimeType="image/*" />
        </intent>
    </queries>

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:name=".App"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyWallet">
        <activity
            android:name=".feature.mine.withdraw.WithdrawActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustPan|stateHidden" />
        <activity
            android:name=".feature.mine.withdraw.WithdrawRecordsActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.main.customer_service.CustomerServiceActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.tutorial.TutorialDetailActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.bonus.BonusCenterActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.mine.SetPasswordActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.mine.PersonalActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.team.SublineActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.wallet.EditUpiActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.wallet.PayChannelSetupActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.mine.PinActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.mine.BindTgActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.wallet.PayChannelActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.tutorial.TutorialActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.splash.SplashActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".feature.main.MainActivity"
            android:exported="true"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.mine.login.LoginActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.home.HomeActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.mine.order.OrderActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.mine.bills.BillsActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.deposit.PaymentDetailActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".feature.deposit.DepositActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="stateHidden" />

        <service
            android:name=".feature.deposit.PaymentReferenceOverlayService"
            android:exported="false" />

        <activity
            android:name=".feature.mine.register.RegisterActivity"
            android:exported="false"
            android:screenOrientation="portrait" /> <!-- 适配华为（huawei）刘海屏 -->
        <meta-data
            android:name="android.notch_support"
            android:value="true" /> <!-- 适配小米（xiaomi）刘海屏 -->
        <meta-data
            android:name="notch.config"
            android:value="portrait|landscape" /> <!-- AndroidAutoSize 设计稿尺寸配置 -->
        <meta-data
            android:name="design_width_in_dp"
            android:value="375" />
        <meta-data
            android:name="design_height_in_dp"
            android:value="667" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>